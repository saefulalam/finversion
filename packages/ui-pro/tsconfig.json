{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "declaration": true,
    "declarationDir": "dist",
    "outDir": "dist",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "paths": {
      "@fv-ui/core": ["../ui/src"],
      "@fv-ui/shared": ["../shared/src"]
    }
  },
  "include": ["src"],
  "references": [
    { "path": "../ui" },
    { "path": "../shared" }
  ]
}